#!/usr/bin/env bash
set -euo pipefail

baseAppId="dev.cherryridge.cherrygrove"

appImagePath="${APPIMAGE:-$0}"
appImageHash="$(printf '%s' "$appImagePath" | sha256sum | cut -c1-16)"

instanceAppId="${baseAppId}.${appImageHash}"

applicationsDir="${XDG_DATA_HOME:-$HOME/.local/share}/applications"
iconsDir="${XDG_DATA_HOME:-$HOME/.local/share}/icons/hicolor/256x256/apps"

desktopFilePath="${applicationsDir}/${instanceAppId}.desktop"
iconFilePath="${iconsDir}/${instanceAppId}.png"
iconSourcePath="${APPDIR}/cherrygrove.png"

mkdir -p "$applicationsDir" "$iconsDir"

if [ ! -f "$iconFilePath" ]; then
    cp "$iconSourcePath" "$iconFilePath"
fi

cat > "$desktopFilePath" <<EOF
[Desktop Entry]
Type=Application
Name=CherryGrove
Exec=/home/ljm12914/Desktop/CherryGrove_linux_x64.AppImage
Path=/home/ljm12914/Desktop
Icon=${instanceAppId}
Terminal=false
Categories=Game;
StartupNotify=true
StartupWMClass=${instanceAppId}
EOF

gtk-update-icon-cache -q "${XDG_DATA_HOME:-$HOME/.local/share}/icons/hicolor" 2>/dev/null || true
update-desktop-database "$applicationsDir" 2>/dev/null || true

export SDL_APP_ID="$instanceAppId"
export SDL_APP_NAME="CherryGrove"

exec "$APPDIR/CherryGrove" "$@"